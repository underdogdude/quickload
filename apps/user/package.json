{
  "name": "@quickload/user",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NEXT_DISABLE_FILE_SYSTEM_CACHE=1 next dev --hostname 0.0.0.0 --port 3000",
    "clean": "rm -rf .next",
    "dev:clean": "pnpm run clean && pnpm run dev",
    "build": "next build",
    "start": "next start",
    "preview": "sh -c 'if lsof -ti:3000 >/dev/null 2>&1; then lsof -ti:3000 | xargs kill; fi; next build && next start --hostname 0.0.0.0 --port 3000'",
    "lint": "next lint"
  },
  "dependencies": {
    "@line/liff": "^2.24.0",
    "@quickload/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "iron-session": "^8.0.4",
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swiper": "^12.1.3",
    "thailand-address-database": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}

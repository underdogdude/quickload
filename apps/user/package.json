{
  "name": "@quickload/user",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3020",
    "clean": "rm -rf .next",
    "dev:clean": "pnpm run clean && pnpm run dev",
    "build": "next build",
    "start": "next start",

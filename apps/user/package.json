    "bwip-js": "^4.10.1",
    "drizzle-orm": "^0.38.3",
    "iron-session": "^8.0.4",
    "jsbarcode": "^3.12.3",
    "next": "^14.2.21",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "promptpay-qr": "^0.5.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",

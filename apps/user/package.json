{
  "name": "@quickload/user",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3020",
    "clean": "rm -rf .next",
    "dev:clean": "pnpm run clean && pnpm run dev",
    "build": "next build",
    "start": "next start",
    "preview": "sh -c 'if lsof -ti:3020 >/dev/null 2>&1; then lsof -ti:3020 | xargs kill; fi; next build && next start --hostname 0.0.0.0 --port 3020'",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fontsource/noto-sans-thai": "^5.2.8",
    "@line/liff": "^2.24.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@quickload/shared": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bwip-js": "^4.10.1",
    "drizzle-orm": "^0.38.3",
    "iron-session": "^8.0.4",
    "jsbarcode": "^3.12.3",
    "next": "^14.2.21",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "promptpay-qr": "^0.5.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "swiper": "^12.1.3",
    "thailand-address-database": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}

{
  "name": "quickload-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:user": "pnpm --filter @quickload/user dev",
    "dev:user:clean": "pnpm --filter @quickload/user dev:clean",
    "preview:user": "pnpm --filter @quickload/user preview",
    "tunnel:user": "ngrok http http://127.0.0.1:3020 --host-header=rewrite",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @quickload/shared db:generate",
    "db:push": "pnpm --filter @quickload/shared db:push",
    "db:studio": "pnpm --filter @quickload/shared db:studio",
    "db:sender": "pnpm --filter @quickload/shared db:apply:sender",
    "db:recipient": "pnpm --filter @quickload/shared db:apply:recipient",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=18"
  }
}

# --- Local Supabase (this repo) ---
# From repo root: `pnpm supabase:start` (Docker required). Studio: http://127.0.0.1:55323
# Ports use 5532x so another default Supabase stack (5432x) can run in parallel.
# After start, copy fresh values: `supabase status -o env`
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
# SUPABASE_URL=http://127.0.0.1:55321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY from supabase status -o env>
# SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY from supabase status -o env>
# Then apply Drizzle schema: `DATABASE_URL=... pnpm db:push` (or set DATABASE_URL in packages/shared/.env)

# Shared / Drizzle (Supabase Postgres — transaction pooler :6543 recommended for hosted)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# apps/user (.env.local)
# Local dev only: skip LIFF + session gate (never enable in production)
NEXT_PUBLIC_DEV_SKIP_LINE_AUTH=
NEXT_PUBLIC_LIFF_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
IRON_SESSION_PASSWORD=
LEGACY_API_BASE_URL=http://legacy-system.example.com/api

# apps/admin (.env.local)
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LEGACY_API_BASE_URL=http://legacy-system.example.com/api

# Beam Checkout (apps/user) — use playground URL for sandbox, api URL for prod.
BEAM_API_BASE_URL=https://playground.api.beamcheckout.com
BEAM_MERCHANT_ID=
BEAM_API_KEY=
BEAM_WEBHOOK_HMAC_KEY=

# Dev-only: renders the "[DEV] simulate paid" button on /pay/[parcelId].
# Must be unset in staging/production.
NEXT_PUBLIC_PAYMENT_MOCK=

# Dev-only: shows "[DEV] จำลองชั่งน้ำหนักจริง" on /parcels (POST /api/dev/pricing-estimate).
# Send/review always uses real Smartpost. Must be unset in staging/production.
NEXT_PUBLIC_SMARTPOST_MOCK=1

# Smartpost getcost (pricing) — vip host, separate from addItem webservice.
SMARTPOST_GETCOST_BASE_URL=https://vip.getsmartpost.com/customer/thaipost/
SMARTPOST_GET_PRICE_PATH=getcost.php
SMARTPOST_USER_CODE=NO48-166

# Smartpost webservice (addItem) — original env; docs: api.getsmartpost.com/webservice/addItem
SMARTPOST_API_BASE_URL=https://api.getsmartpost.com/webservice/
SMARTPOST_ADD_ITEM_PATH=addItem
SMARTPOST_BASIC_AUTH_USERNAME=ssslineoa
SMARTPOST_BASIC_AUTH_PASSWORD=SSS12345

# Webhook auth for Smartpost status callbacks (POST /api/parcels/thai-post-webhook).
# Smartpost signs the body with HMAC-SHA256 using this secret (header: X-Webhook-Signature).
# Must match the `webhook_secret` value stored in tb_webhook_endpoints for your customer_code.
# If unset, falls back to the simple X-Webhook-Token header check below.
SMARTPOST_WEBHOOK_SECRET=

# Legacy simple-token auth (used when SMARTPOST_WEBHOOK_SECRET is unset).
THAI_POST_WEBHOOK_TOKEN=

# Shared secret for cron-callable endpoints (e.g. /api/payment/sweep-abandoned).
# Send as `X-Cron-Token: <value>` header. Generate a long random string in production.
CRON_SECRET=

# Thaibulksms OTP (apps/user — registration + phone change). Keys from OTP Console.
THAIBULKSMS_OTP_API_KEY=
THAIBULKSMS_OTP_API_SECRET=

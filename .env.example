# Shared / Drizzle (Supabase Postgres — transaction pooler :6543 recommended)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# apps/user (.env.local)
# Local dev only: skip LIFF + session gate (never enable in production)
NEXT_PUBLIC_DEV_SKIP_LINE_AUTH=
NEXT_PUBLIC_LIFF_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
IRON_SESSION_PASSWORD=
LEGACY_API_BASE_URL=http://legacy-system.example.com/api

# apps/admin (.env.local)
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LEGACY_API_BASE_URL=http://legacy-system.example.com/api
